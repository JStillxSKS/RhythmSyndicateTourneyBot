# Discord application bot token (Developer Portal → Bot)
DISCORD_TOKEN=

# Rhythm Syndicate guild + channels
RS_GUILD_ID=
RS_CHANNEL_ID=
# Optional: separate score-submit channel (defaults to RS_CHANNEL_ID)
# RS_SUBMIT_CHANNEL_ID=

# Comma-separated role IDs allowed to run /rs commands
# (Manage Server always allowed as fallback)
RS_ADMIN_ROLE_IDS=

# Optional override for state file path (default: data/rs_state.json)
# RS_STATE_PATH=

# Automation (default ON). Set to 0/false/off to disable.
# RS_AUTO_WEEK=1
# RS_AUTO_ANNOUNCE=1
# RS_AUTO_DIGEST=1
# RS_BOARD_THROTTLE_SEC=45
# RS_SCHEDULER_TICK_SEC=45

# Fast test clock: 1 real minute = 1 virtual hour (default). Use on test server only.
# RS_TEST_TIME=1
# RS_TEST_VHOURS_PER_RMIN=1
# Then: /rs season test-reset anchor:before open  → open ~10 real minutes later
