# Discord application bot token (Developer Portal → Bot)
DISCORD_TOKEN=

# Rhythm Syndicate guild + channels
RS_GUILD_ID=
RS_CHANNEL_ID=
# Optional: separate score-submit channel (defaults to RS_CHANNEL_ID)
# RS_SUBMIT_CHANNEL_ID=

# Comma-separated role IDs allowed to run /rs commands
# (Manage Server always allowed as fallback)
RS_ADMIN_ROLE_IDS=

# Optional override for state file path (default: data/rs_state.json)
# RS_STATE_PATH=
